# ─────────────────────────────────────────────────────────────────────────────
# ZITADEL Login App (sibling scaffold)
#
# These variables mirror the upstream ZITADEL Login UI v2 contract. The upstream
# app talks to a ZITADEL instance's API using a service-user token. Copy this
# file to `.env.local` and fill in real values. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the ZITADEL instance API (no trailing slash), e.g.
# https://your-instance.zitadel.cloud
ZITADEL_API_URL=

# Service user PAT used by the Login App to call the ZITADEL API on behalf of
# the login flows. Create a machine user with the required roles and generate a
# personal access token. Treat as a secret.
ZITADEL_SERVICE_USER_TOKEN=

# Optional: override the default request cookie / debug behavior in local dev.
# DEBUG=false

# Port is set via the dev/start scripts (3001) to avoid clashing with the Main
# App on 3000.
