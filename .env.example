# --- Database -------------------------------------------------------------
# Postgres locale o remoto.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gausio

# --- Auth.js ---------------------------------------------------------------
# Genera con: npx auth secret
AUTH_SECRET=change-me
# URL pubblico dell'app (necessario dietro proxy / in produzione).
AUTH_URL=http://localhost:3000

# URL canonico usato da metadata, sitemap.xml e robots.txt.
NEXT_PUBLIC_SITE_URL=https://gausio.com

# --- Zitadel ---------------------------------------------------------------
# Issuer della tua istanza Zitadel (es. https://tuaistanza.zitadel.cloud)
AUTH_ZITADEL_ISSUER=
# Client ID/Secret dell'applicazione OIDC (code flow + PKCE) creata in Zitadel.
# Vedi docs/ZITADEL_CONFIGURATION.md per dove trovarli nella console.
AUTH_ZITADEL_ID=
AUTH_ZITADEL_SECRET=

# Base URL della Login App self-hosted (ZITADEL Login UI v2). Se impostata,
# l'authorize endpoint OIDC passa dalla Login App invece della hosted login
# (es. https://login.tuodominio.it/ui/v2/login). Vuota = hosted login.
ZITADEL_LOGIN_BASE_URL=

# URL pubblico della Main App per il post_logout_redirect_uri assoluto del
# logout federato. Se vuota si usa AUTH_URL / NEXT_PUBLIC_SITE_URL.
APP_BASE_URL=

# --- Sviluppo --------------------------------------------------------------
# true per abilitare il login di sviluppo senza Zitadel (solo in locale!).
AUTH_DEV_LOGIN=true

# Cartella (relativa alla root) dove salvare gli allegati caricati.
UPLOADS_DIR=storage/uploads
