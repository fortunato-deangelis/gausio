# --- Database -------------------------------------------------------------
# Postgres locale o remoto.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gausio

# --- Auth.js ---------------------------------------------------------------
# Genera con: npx auth secret
AUTH_SECRET=change-me
# URL pubblico dell'app (necessario dietro proxy / in produzione).
AUTH_URL=http://localhost:3000

# URL canonico usato da metadata, sitemap.xml e robots.txt.
NEXT_PUBLIC_SITE_URL=https://gausio.com

# --- Zitadel ---------------------------------------------------------------
# Issuer della tua istanza Zitadel (es. https://tuaistanza.zitadel.cloud)
AUTH_ZITADEL_ISSUER=
# Client ID dell'applicazione OIDC (code flow + PKCE) creata in Zitadel.
AUTH_ZITADEL_ID=
# Client Secret: solo se l'app usa Authentication Method "Basic"/"Post".
# Con Authentication Method "None" (PKCE, public client) lasciare vuoto.
AUTH_ZITADEL_SECRET=

# --- Zitadel: login UI custom -----------------------------------------------
# PAT del service user con ruolo "Instance Login Client" (IAM_LOGIN_CLIENT).
# Obbligatorio per le pagine di accesso custom (feature Login V2 con
# baseUri = <AUTH_URL>/api). Vedi docs/ZITADEL_CONFIGURATION.md.
ZITADEL_SERVICE_USER_TOKEN=

# --- Sviluppo --------------------------------------------------------------
# In locale usare un'applicazione OIDC Zitadel dedicata allo sviluppo
# (stesse variabili AUTH_ZITADEL_* / ZITADEL_* con i valori dell'app dev).

# Cartella (relativa alla root) dove salvare gli allegati caricati.
UPLOADS_DIR=storage/uploads
